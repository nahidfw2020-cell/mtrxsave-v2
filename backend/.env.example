PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS allowlist, comma-separated
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# HMAC secret for signing download tokens (32+ bytes hex/base64)
TOKEN_SECRET=replace-with-strong-random-secret-min-32-chars
TOKEN_TTL_SECONDS=600

# Binary paths (auto-resolved from PATH if blank)
YTDLP_PATH=
FFMPEG_PATH=

# Optional cookie jar for IG/FB private content
COOKIE_JAR_PATH=

# Concurrency caps
MAX_CONCURRENT_YTDLP=20
MAX_CONCURRENT_PUPPETEER=3
PER_IP_CONCURRENT_DOWNLOADS=2

# Temp dir for staged files
TEMP_DIR=./temp
TEMP_MAX_AGE_MINUTES=30

# Rate limits (per IP per minute)
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_DOWNLOAD=30
